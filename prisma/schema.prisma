
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model inventory{
    productId String @id
    availableStock Int
    reservedStock Int
    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())
}
enum MessageStatus{
    PENDING
    QUEUED
    SENT
}

model Notification{
    id String @id @default(uuid())
    userid String
    status MessageStatus @default(PENDING)
    message String
    createdAt DateTime @default(now())
    deliveredAt DateTime?
}
enum Update{
    PENDING
    PAID 
    FAILED
    CANCELED
}
model Order{
    id String @id @default(uuid())
    userId String
    total_amount Decimal @db.Decimal(10,2)
    status Update @default(PENDING)
    createdAt DateTime @default(now())

    orders OrderItems[]
}

model OrderItems{
    id String @id @default(uuid())
    productid String
    orderid String
    price_at_purchase Decimal @db.Decimal(10,2)
    quantity Int

    order Order @relation(fields: [orderid], references: [id])
    @@unique([productid,orderid])
}
enum Status{
    PENDING
    SUCCESS
    FAILED
}
model Payment{
    id String @id @default(uuid())
    orderid String
    amount Decimal @db.Decimal(10,2)
    status Status @default(PENDING)
    createdAt DateTime @default(now())
}
model Category{
    id String @id @default(uuid())
    name String
    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())

    products Product[]
}

model Product{
    id String @id @default(uuid())
    retailerId String
    name String
    description String
    category String
    price Decimal @db.Decimal(10, 2)
    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())

    cartIn CartItems[]
    cat Category @relation(fields: [category], references: [id])
    retailer User @relation(fields: [retailerId],references: [id])
}

enum Role{
    Admin
    User
    Retailer
}
model User{
    id String @id @default(uuid())
    name String
    role Role @default(User)
    email String @unique
    password String
    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())

    products Product[]
    refreshTokens RefreshToken[]
}

model RefreshToken{
    id String @id @default(uuid())
    jti String @unique
    tokenHash String
    userId String
    revoked Boolean
    replacedBy String
    createdAt DateTime @default(now())
    revokedAt DateTime?
    expiresAt DateTime

    user User @relation(fields: [userId], references: [id])
}

model CartItems{
    id String @id @default(uuid())
    cartId String
    productId String
    quantity Int @default(1)
    price Decimal @db.Decimal(10,2)
    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())
    cart Cart @relation(fields: [cartId],references: [id])
    cartProduct Product @relation(fields: [productId], references: [id]) 
    @@unique([cartId,productId])
    
}

model Cart{
    id String @id @default(uuid())
    userId String
    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())
    
    cartItems CartItems[]
}